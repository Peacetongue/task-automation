.env
.env.local
.env.*.local

# Hermes runtime state — mounted как bind, не коммитим ничего кроме config.yaml и skills/
hermes/sessions/
hermes/logs/
hermes/cache/
hermes/memories/
hermes/plans/
hermes/workspace/
hermes/home/
hermes/cron/
hermes/hooks/
hermes/skins/
hermes/.env
hermes/.skills_prompt_snapshot.json

# Hermes на старте синкает 70+ встроенных скиллов в /opt/data/skills —
# коммитим только наши. Whitelist через !-паттерны.
hermes/skills/*
!hermes/skills/aigateway/
!hermes/skills/team_directory/
!hermes/skills/team_message/
!hermes/skills/team_admin/
!hermes/skills/team_approval/
!hermes/skills/setup/
!hermes/skills/jira/
!hermes/skills/confluence/
!hermes/skills/gitlab/

# Per-user credentials — никогда не коммитим.
corp_mcp_proxy/data/
config/team.yaml
!config/team.yaml.example
hermes/channel_directory.json
hermes/gateway.pid
hermes/gateway_state.json
hermes/state.db*
hermes/sandboxes/
hermes/platforms/
hermes/bin/
hermes/.local/
hermes/models_dev_cache.json
hermes/ollama_cloud_models_cache.json

# macOS / IDE
.DS_Store
.idea/
.vscode/
*.swp
