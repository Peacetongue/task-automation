# ─────────────────────────────────────────────────────────────────────────────
# Telegram (required)
# ─────────────────────────────────────────────────────────────────────────────
# 1. Создай бота у @BotFather → получи токен.
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# 2. Через @userinfobot узнай numeric ID тимлида и свой.
#    Разделитель — запятая, без пробелов. Только эти пользователи смогут
#    писать боту — все остальные отбиваются на уровне gateway'а Hermes.
TELEGRAM_ALLOWED_USERS=111111111,222222222


# ─────────────────────────────────────────────────────────────────────────────
# LLM — COMPANY AI Gateway (required, единственный канал для LLM)
# ─────────────────────────────────────────────────────────────────────────────
# Base URL строго БЕЗ trailing slash. На обеих площадках одинаковый.
OPENAI_BASE_URL=https://aigateway.company.ru/api/v2

# Токен API v1/v2. Запросить у админа gateway'а (POST /api/v1/auth/tokens)
# либо сгенерировать через админку. Начинается с "sk-".
OPENAI_API_KEY=sk-REPLACE_ME

# Модель ОБЯЗАТЕЛЬНО в формате "Provider/Name". Плоские имена (gpt-4o)
# gateway отклонит 400. Список доступных: GET ${OPENAI_BASE_URL}/models.
# Примеры: InHouse/Qwen3.5-122B, OpenAI/GPT-5.4, OpenRouter/Claude-Sonnet-4.6.
HERMES_MODEL=InHouse/Qwen3.5-122B


# ─────────────────────────────────────────────────────────────────────────────
# Vikunja (required; API_TOKEN и DEFAULT_PROJECT_ID заполняются
# после первого запуска UI — см. README шаги 3–5)
# ─────────────────────────────────────────────────────────────────────────────
# openssl rand -hex 32
VIKUNJA_SERVICE_SECRET=REPLACE_WITH_openssl_rand_hex_32

# Пароль postgres-пользователя vikunja (внутренний, наружу не торчит).
VIKUNJA_DB_PASSWORD=change-me

# Публичный URL, по которому открывается Vikunja UI.
# На Linux-проде — замени на http(s)://your-host/.
VIKUNJA_PUBLIC_URL=http://localhost:3456/

# API-токен с правами tasks:read, tasks:write. Создаётся в UI:
# Settings → API Tokens → New token.
VIKUNJA_API_TOKEN=tk_REPLACE_ME

# ID дефолтного "Inbox" проекта. Первый созданный проект обычно имеет ID=1.
VIKUNJA_DEFAULT_PROJECT_ID=1


# ─────────────────────────────────────────────────────────────────────────────
# Транскрипция (COMPANY Transcribe)
# ─────────────────────────────────────────────────────────────────────────────
# Доступен только изнутри корп.сети (company.loc). Вне VPN — не резолвится,
# shim отдаёт 503 для войсов, это ожидаемо.
TRANSCRIBE_SERVICE_URL=http://ml-platform-big.company.loc:9204

# Потолок ожидания готовности транскрипции, секунд.
TRANSCRIBE_POLL_TIMEOUT=120


# ─────────────────────────────────────────────────────────────────────────────
# Atlassian MCP (TODO — подключим, когда понадобится синк с Jira)
# ─────────────────────────────────────────────────────────────────────────────
# Официальный remote MCP: https://mcp.atlassian.com/v1/mcp (OAuth 2.1).
# Первый хендшейк делается вручную через `hermes mcp` CLI.
# ATL_MCP_OAUTH_CLIENT_ID=
# ATL_MCP_OAUTH_CLIENT_SECRET=
