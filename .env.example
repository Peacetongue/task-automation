# ─────────────────────────────────────────────────────────────────────────────
# Telegram (required)
# ─────────────────────────────────────────────────────────────────────────────
# 1. Создай бота у @BotFather → получи токен.
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# 2. Список пилотных пользователей — numeric IDs через запятую, без пробелов.
#    Источник правды — config/team.yaml. После правки roster'а:
#      bash scripts/sync-team-allowlist.sh
#    заново сгенерирует эту строку из team.yaml и перезапишет её здесь.
TELEGRAM_ALLOWED_USERS=111111111,222222222


# ─────────────────────────────────────────────────────────────────────────────
# LLM — COMPANY AI Gateway (required, единственный канал для LLM)
# ─────────────────────────────────────────────────────────────────────────────
# Base URL строго БЕЗ trailing slash.
OPENAI_BASE_URL=https://aigateway.company.ru/api/v2

# Токен API. Получить у админа gateway'а или через админку.
OPENAI_API_KEY=sk-REPLACE_ME

# Имя модели фиксируется в hermes/config.yaml (env-substitution там ломается
# на auxiliary-пути). По дефолту стоит `InHouse/Qwen3.5-122B`. Чтобы сменить —
# правь config.yaml, не env.


# ─────────────────────────────────────────────────────────────────────────────
# Транскрипция (COMPANY Transcribe)
# ─────────────────────────────────────────────────────────────────────────────
# Доступен только изнутри корп.сети (company.loc). Вне VPN — shim отдаст 503
# на voice-сообщения; текстовые запросы работают.
TRANSCRIBE_SERVICE_URL=http://ml-platform-big.company.loc:9204
TRANSCRIBE_POLL_TIMEOUT=120


# ─────────────────────────────────────────────────────────────────────────────
# Корпоративные сервисы (информационно — HTTP-клиенты читают напрямую,
# но здесь фиксируем для справки и для будущих скриптов)
# ─────────────────────────────────────────────────────────────────────────────
# Jira DC:        https://jira.company.ru
# Confluence DC:  https://confluence.company.ru
# GitLab:         https://gitlab.company.ru
#
# Per-user PAT-ы сотрудники добавляют в бота командой `/setup <service> <pat>`;
# токены сохраняются в volume `corp_tokens` (/opt/data/user_tokens/<id>.json).
# В .env эти секреты НЕ храним.
