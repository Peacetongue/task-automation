# Все ключи с префиксом TA_ (task-automation). Это намеренно: чтобы в
# shell-сессии разработчика случайно экспортированные `TELEGRAM_BOT_TOKEN`
# или `OPENAI_API_KEY` не перебивали значения из .env (docker compose
# при подстановке `${VAR}` смотрит в shell ДО .env). Внутри контейнеров
# переменные живут с нативными именами, префикс только в .env + compose.yml.

# ─────────────────────────────────────────────────────────────────────────────
# Telegram (required)
# ─────────────────────────────────────────────────────────────────────────────
# 1. @BotFather → `/newbot` → токен.
TA_TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# 2. Список разрешённых numeric IDs. По дефолту `*` (wildcard) — значит
#    Hermes пропускает ВСЕХ до SOUL.md, который уже сам решает:
#    - отправитель в team.yaml → нормально обслуживаем;
#    - unknown → trigger'им team_approval (pending-заявка админам).
#    Это основной путь: сотрудник жмёт /start, админ нажимает "одобрь".
#
#    Если хочешь STRICT mode (Hermes отбивает на уровне telegram-адаптера,
#    approval-флоу выключен) — впиши явный список через запятую
#    и синкай его: `bash scripts/sync-team-allowlist.sh`.
TA_TELEGRAM_ALLOWED_USERS=*


# ─────────────────────────────────────────────────────────────────────────────
# LLM — BIOCAD AI Gateway (required)
# ─────────────────────────────────────────────────────────────────────────────
TA_OPENAI_BASE_URL=https://aigateway.biocad.ru/api/v2
TA_OPENAI_API_KEY=sk-REPLACE_ME

# Имя модели зашито в hermes/config.yaml (env-substitution там ломается
# на auxiliary-пути Hermes). Default — `InHouse/Qwen3.5-122B`.


# ─────────────────────────────────────────────────────────────────────────────
# Транскрипция (BIOCAD Transcribe) — опционально
# ─────────────────────────────────────────────────────────────────────────────
# Доступен только внутри корп.сети (biocad.loc). Вне VPN войсы отдадут
# 503; текстовые запросы продолжают работать.
TA_TRANSCRIBE_SERVICE_URL=http://ml-platform-big.biocad.loc:9204
TA_TRANSCRIBE_POLL_TIMEOUT=120


# ─────────────────────────────────────────────────────────────────────────────
# Корпоративные сервисы (информационно)
# ─────────────────────────────────────────────────────────────────────────────
# Jira DC:        https://jira.biocad.ru
# Confluence DC:  https://confluence.biocad.ru
# GitLab:         https://gitlab.biocad.ru
#
# Per-user PAT-ы сотрудники добавляют в бот командой `/setup <service> <pat>`
# (см. skill `setup`). Токены хранятся в volume corp_tokens, в .env их нет.
