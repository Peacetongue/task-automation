# Every text file goes through the sanitize clean-filter на git add.
# The filter lives in scripts/git-sanitize.sh; bootstrap with
# scripts/setup-git-sanitize.sh after cloning.
* filter=sanitize

# Shell scripts must not be sanitized in a way that breaks LF.
# git-unsanitize.sh must bypass smudge so the executable exists before other paths are checked out.
scripts/git-sanitize.sh -filter
scripts/git-unsanitize.sh -filter
